# Required for x_search (xAI Grok API)
XAI_API_KEY=

# Recommended for github_search / github_repo_info (higher rate limits)
GITHUB_TOKEN=

# Required for producthunt_search
PH_CLIENT_ID=
PH_CLIENT_SECRET=

# x402 payment settings (required for HTTP server mode)
EVM_ADDRESS=
NETWORK=eip155:8453
X402_PORT=4023
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# CDP facilitator auth (optional — enables Bazaar Discovery auto-registration)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# RapidAPI proxy authentication (optional — set to enable subscription access)
RAPIDAPI_PROXY_SECRET=

# Pricing (env-configurable for instant adjustment without code change)
PRICE_LOW=$0.005
PRICE_X=$0.20
PRICE_XFULL=$0.25
PRICE_RESEARCH=$0.25
PRICE_RESEARCH_DEEP=$0.50
XAI_COST_PER_CALL=0.05

# Gemini 2.0 Flash-Lite (optional — required for POST /scout/research endpoints)
GEMINI_API_KEY=

# YouTube Data API v3 (required for youtube_search)
YOUTUBE_API_KEY=

# Qiita API v2 (optional — raises rate limit from 60→1000 req/h)
QIITA_TOKEN=

# StackExchange API v2.3 (optional — raises rate limit from 300→10,000 req/day)
SE_API_KEY=

# Semantic Scholar API (optional — dedicated rate limit vs shared)
S2_API_KEY=

# Reddit (required for reddit_search — free for non-commercial/personal use)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Solana pay-to address (optional — if using SVM payment scheme)
SOLANA_PAY_TO=
