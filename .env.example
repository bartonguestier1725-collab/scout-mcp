# Required for x_search (xAI Grok API)
XAI_API_KEY=

# Recommended for github_search / github_repo_info (higher rate limits)
GITHUB_TOKEN=

# Required for producthunt_search
PH_CLIENT_ID=
PH_CLIENT_SECRET=

# x402 payment settings (required for HTTP server mode)
EVM_ADDRESS=
NETWORK=eip155:8453
X402_PORT=4023
FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402

# CDP facilitator auth (optional — enables Bazaar Discovery auto-registration)
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# RapidAPI proxy authentication (optional — set to enable subscription access)
RAPIDAPI_PROXY_SECRET=
